# Supabase — get these from your Supabase project settings > API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# OpenAI — used for style embeddings, query generation, and modesty filtering
OPENAI_API_KEY=
OPENAI_EMBED_MODEL=text-embedding-3-small

# SerpApi — used by the product discovery pipeline
SERPAPI_KEY=

# Pinterest OAuth — create an app at developers.pinterest.com
PINTEREST_CLIENT_ID=
PINTEREST_CLIENT_SECRET=
PINTEREST_REDIRECT_URI=http://localhost:3000/api/pinterest/callback
PINTEREST_SCOPES=boards:read,pins:read

# App URL — used for OAuth redirects. Set to your production domain when deploying.
NEXT_PUBLIC_APP_URL=http://localhost:3000
